# Database files (use Turso cloud database instead)
*.db
*.sqlite
*.sqlite3
app/demo.db
app/*.db
data/*.db

# Large data files (exclude pkl but keep onnx)
turso_dump.sql
*.sql
*.csv
*.csv.bz2
*.pkl
data/*.txt
data/**/*.txt
/data/*.db
/data/models/*/*.pkl
/data/fjc/
data/fjc/
data/opinion-clusters.csv.bz2
# Keep ONNX models - explicit inclusion
!data/models/
!data/models/v1.0.0/
!data/models/v1.0.0/onnx/
!data/models/v1.0.0/onnx/*.onnx
!data/models/v1.0.0/metadata.json

# Development files
.env
.env.local
.claude/
__pycache__/
*.pyc
.pytest_cache/
venv/
.venv/

# Logs and temp files
*.log
server.log
logs/
reports/

# PACER credentials and cookies
.pacer_cookies.json
pacer_*.html
direct_login_response.html
headers_login_response.html

# Docs and fixtures (not needed for deployment)
docs/
fixtures/
*.md
!README.md

# Scripts (not needed at runtime)
scripts/
*.sh

# Downloaded documents
docs_cache/
downloads/

# Scripts with large model files
scripts/*.pkl
